rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Portfolio collections: Everyone can read, only authenticated admins can write
    match /projects/{document=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /experiences/{document=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /qualifications/{document=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /testimonials/{document=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /about/{document=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /gallery_images/{document=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /skills/{document=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    // Messages: Everyone can create, only authenticated admins can read/delete
    match /messages/{document=**} {
      allow create: if true;
      allow read, write: if request.auth != null;
    }
  }
}
